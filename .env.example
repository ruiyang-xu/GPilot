# GPilot — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then run: bash scripts/customize.sh

# ============================================
# REQUIRED — Your Identity
# ============================================

USER_NAME="Your Name"
USER_INITIALS="YN"
ORG_NAME="Acme Ventures"

# Focus sectors (comma-separated)
FOCUS_SECTORS="Software/SaaS, AI/ML, Fintech, Healthtech, Deeptech"

# ============================================
# REQUIRED — API Keys
# ============================================

# Perplexity AI (for deep research agent)
# Get yours at: https://perplexity.ai/settings/api
PERPLEXITY_API_KEY=""

# ============================================
# OPTIONAL — Cloud Storage Paths (macOS only)
# Used by modules/fund-ops/scripts/refresh-projects.sh
# ============================================

HUB_PATH="$HOME/Documents/gpilot"
ONEDRIVE_PATH=""
GDRIVE_PATH=""
GDRIVE_EMAIL=""

# ============================================
# OPTIONAL — Feishu / Lark (Chinese workspace)
# Only needed if you use Feishu for collaboration
# See modules/integrations/feishu/ for setup
# ============================================

FEISHU_OPEN_ID=""
